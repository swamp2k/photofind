{
  "name": "photofind",
  "version": "0.1.0",
  "description": "Local AI Photo Curator - repair Google Takeout exports, browse, curate, and export photo libraries",
  "private": true,
  "author": "Photofind",
  "desktopName": "photofind.desktop",
  "type": "module",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run rebuild:electron && electron-vite dev",
    "build": "electron-vite build",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-builder install-app-deps",
    "pack:linux": "npm run build && electron-builder --linux dir && npm run rebuild:node",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb && npm run rebuild:node",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "npm run rebuild:node && vitest run"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.11.1",
    "exiftool-vendored": "^35.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "dev.photofind.app",
    "productName": "Photofind",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@vladmandic/face-api/model/**",
      "node_modules/@tensorflow/tfjs-backend-wasm/dist/*.wasm"
    ],
    "linux": {
      "category": "Graphics",
      "maintainer": "Photofind",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
